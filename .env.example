# Copy to .env and fill in.

# --- LLM scoring (risk verdict synthesis) ---
# Provide a key for whichever provider you want to use. If neither key is set,
# the pipeline falls back to a deterministic MOCK reasoning engine so it still
# produces a PDF without any API key.
#
# LLM_PROVIDER selects the backend: auto | anthropic | gemini
#   auto (default) prefers Claude when both keys are present.
LLM_PROVIDER=auto

# Claude (Anthropic)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# Gemini (Google)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# --- Langflow REST API (only needed when running through the flow/UI) ---
LANGFLOW_URL=http://localhost:7860
LANGFLOW_FLOW_ID=credit-analyst
# LANGFLOW_API_KEY=    # if your Langflow instance requires auth

# --- Paths (defaults are fine for local dev) ---
# Project root used by all components to resolve data/ inputs/ outputs/.
# REQUIRED when running through Langflow: under Langflow's exec, __file__ is None,
# so without this the components fall over with
#   "Error creating class. TypeError(expected str, bytes or os.PathLike object, not NoneType)".
# Set it to the absolute path of this repo on your machine.
CREDIT_ANALYST_ROOT=/absolute/path/to/credit_risk_narrative_generator
INPUTS_DIR=inputs
OUTPUTS_DIR=outputs
